# ====================================
# FastAPI Configuration
# ====================================
APP_NAME='IA Service - Smart Parking'
APP_VERSION=1.0.0
APP_HOST=0.0.0.0
APP_PORT=8083
DEBUG=True

# ====================================
# CORS Configuration (Angular Frontend)
# ====================================
CORS_ORIGINS=http://localhost:4200,http://localhost:8080

# ====================================
# MongoDB Configuration
# ====================================
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=smart_parking_ia
MONGODB_MIN_POOL_SIZE=10
MONGODB_MAX_POOL_SIZE=100

# ====================================
# Deep Learning - YOLO Configuration
# ====================================
YOLO_MODEL_PATH=app/ml/dl/models/yolo26n.pt
YOLO_CONFIDENCE_THRESHOLD=0.25
YOLO_IOU_THRESHOLD=0.45
YOLO_MAX_DETECTIONS=10
YOLO_DEVICE=cpu

# ====================================
# Deep Learning - OCR Configuration
# ====================================
OCR_LANGUAGES=en,es
OCR_GPU=False
OCR_MIN_CONFIDENCE=0.5
OCR_PARAGRAPH=False

# ====================================
# Image Processing
# ====================================
MAX_IMAGE_SIZE_MB=10
ALLOWED_IMAGE_FORMATS=jpg,jpeg,png
IMAGE_RESIZE_WIDTH=640
IMAGE_RESIZE_HEIGHT=640

# ====================================
# Logging Configuration
# ====================================
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s-%(name)s-%(levelname)s-%(message)s
LOG_FILE_PATH=logs/ia-service.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ====================================
# API Gateway Configuration (Eureka)
# ====================================
EUREKA_SERVER_URL=http://localhost:8761/eureka
SERVICE_NAME=ia-service
SERVICE_INSTANCE_ID=ia-service-1

# ========================================
# S3/MinIO Configuration
# ========================================
S3_ENDPOINT=localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=smart-parking
S3_SECURE=false